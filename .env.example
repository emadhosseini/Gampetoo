# Copy this file to .env.local (gitignored) and fill in your Supabase project's
# values — Project Settings → API in the Supabase dashboard.
# The anon key is safe to expose client-side; Row Level Security in
# supabase/schema.sql is what actually protects each user's data.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
